{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.ozers/hooksense",
  "description": "Webhook & callback layer for AI agents: create a URL, wait_for_callback, and verify over MCP.",
  "repository": {
    "url": "https://github.com/ozers/hooksense-mcp",
    "source": "github"
  },
  "version": "0.2.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@hooksense/mcp",
      "version": "0.2.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "HOOKSENSE_TOKEN",
          "description": "API token from https://hooksense.com/account/tokens",
          "isRequired": true,
          "isSecret": true,
          "format": "string"
        },
        {
          "name": "HOOKSENSE_API",
          "description": "Override the API base URL (self-hosted / staging). Defaults to https://hooksense.com",
          "isRequired": false,
          "format": "string"
        }
      ]
    }
  ]
}
